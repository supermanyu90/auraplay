# Required — all free
VITE_LASTFM_API_KEY=         # https://www.last.fm/api/account/create
VITE_YOUTUBE_API_KEY=        # https://console.cloud.google.com
VITE_OPENWEATHER_API_KEY=    # https://openweathermap.org/api

# Optional alternative playback sources (all free)
VITE_JAMENDO_CLIENT_ID=      # https://devportal.jamendo.com/  — Creative Commons full songs
# Audius needs no key — discovery node is fetched at runtime

# Optional — for user accounts (free tier)
VITE_SUPABASE_URL=           # https://supabase.com
VITE_SUPABASE_ANON_KEY=
